# Site
NEXT_PUBLIC_SITE_URL=https://your-domain.example

# Base.dev (explicit <meta name="base:app_id" />)
NEXT_PUBLIC_BASE_APP_ID=

# Chain (Base mainnet = 8453)
NEXT_PUBLIC_CHAIN_ID=8453

# CheckIn.sol on Base mainnet (this repo’s deploy — override in .env.local if you redeploy)
NEXT_PUBLIC_CHECK_IN_CONTRACT_ADDRESS=0xdd1A0C39a55Ef9fd718B11731fc073C1EB3AA7dF

# Builder Code from base.dev (bc_…); used with ox Attribution.toDataSuffix
NEXT_PUBLIC_BUILDER_CODE=

# Rare override: raw 0x suffix instead of bc code
# NEXT_PUBLIC_BUILDER_CODE_SUFFIX=

# Optional WalletConnect
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
